# name: test/sql/languages.test
# group: [vgi_grammar]
#
# grammar_languages() lists supported codes; unknown language is a clear error.

require-env VGI_GRAMMAR_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'grammar' AS grammar (TYPE vgi, LOCATION '${VGI_GRAMMAR_WORKER}');

# ---- grammar_languages: non-empty, includes en-US ---------------------------

query I
SELECT count(*) > 0 FROM grammar.grammar_languages();
----
true

query I
SELECT count(*) > 0 FROM grammar.grammar_languages() WHERE code = 'en-US';
----
true

# every row has a code and a name.
query I
SELECT count(*) FROM grammar.grammar_languages() WHERE code IS NULL OR name IS NULL;
----
0

# ---- unknown language -> clear error ----------------------------------------

statement error
SELECT grammar.grammar_count('Some text.', 'xx-ZZ');
----

statement ok
DETACH grammar;
